# Groq (OpenAI-compatible API): speech-to-text + structured extraction by default
GROQ_API_KEY=gsk_...
# Optional overrides:
# GROQ_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile

# If set, extraction uses OpenAI instead of Groq (transcription still uses Groq + GROQ_API_KEY)
OPENAI_API_KEY=sk-...
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini
# DATABASE_URL=sqlite:///./emotiongraph.db
# Optional: override allowed browser origins (comma-separated). Defaults include local Vite + deployed frontend.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://web-production-abed5.up.railway.app

# Optional outbound HTTP proxy (single URL; not applied to API clients yet)
# USE_OUTBOUND_PROXY=false
# OUTBOUND_PROXY_URL=http://username:password@ip:port

# Local API URL: http://127.0.0.1:8100
# From backend/ (after venv + pip install): .venv/bin/uvicorn app.main:app --reload --host 127.0.0.1 --port 8100
