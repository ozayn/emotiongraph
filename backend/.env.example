# --- Speech-to-text (POST /transcribe) — Groq only ---
GROQ_API_KEY=gsk_...
# GROQ_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# --- Structured extraction (POST /extract-logs) ---
# Primary: Claude (Anthropic). If Claude errors, times out, or returns invalid JSON vs schema, the server falls back to Groq.
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_TIMEOUT_SECONDS=90

# Fallback (same key as transcription is fine): Groq chat with JSON mode
# GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile

# Local (default): SQLite file under the backend working directory (path is relative to the process cwd, usually backend/)
# If this file predates the multi-user schema, the app renames it to *.bak.<timestamp> once and creates a fresh DB (data not migrated).
# DATABASE_URL=sqlite:///./emotiongraph.db
# Production: PostgreSQL (Railway/Heroku often provide postgres:// — the app normalizes that)
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
# Schema changes: Alembic (see backend/MIGRATIONS.md). On startup the app runs pending migrations (upgrade head).
# PostgreSQL DBs missing older multi-user columns may still be ALTERed by startup helpers after seed — see app.db.upgrade_rdbms_schema_for_multiuser.
# Optional: comma-separated browser origins (must match the page origin exactly). The API unions this
# list with built-in defaults (localhost + emotiongraph.ozayn.com + legacy Railway UI host) so a
# production CORS_ORIGINS that only lists *.railway.app still allows your custom domain.
# CORS_ORIGINS=https://your-frontend.up.railway.app

# Optional outbound HTTP proxy (single URL; not applied to API clients yet)
# USE_OUTBOUND_PROXY=false
# OUTBOUND_PROXY_URL=http://username:password@ip:port

# Frontend public demo (`/demo/*`) can pin to one user via VITE_DEMO_USER_ID — seed a dedicated
# demo account in the DB. Private app (`/`) uses Google Sign-In + JWT when configured.

# --- Google Sign-In + API sessions (private app) ---
# OAuth 2.0 Client ID (Web application) from Google Cloud Console — must match the frontend VITE_GOOGLE_CLIENT_ID.
# GOOGLE_OAUTH_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
#
# Secret for signing API access JWTs after Google ID token verification (use a long random string; never expose to clients).
# AUTH_JWT_SECRET=generate-a-long-random-string-at-least-32-chars
# Optional: access token lifetime in seconds (default 604800 = 7 days).
# AUTH_JWT_EXP_SECONDS=604800
#
# Google Cloud setup (summary):
# 1. Create or select a project → APIs & Services → Enable "Google Identity Services" (Sign in with Google uses this).
# 2. Credentials → Create credentials → OAuth client ID → Application type: Web application.
# 3. Authorized JavaScript origins: your site origins (e.g. https://emotiongraph.example.com, http://localhost:5173 for dev).
# 4. Authorized redirect URIs: not required for the GIS popup/one-tap credential flow (leave empty or use Google’s note for your client type).
# 5. Copy the Client ID into GOOGLE_OAUTH_CLIENT_ID (backend) and VITE_GOOGLE_CLIENT_ID (frontend build).
# 6. OAuth consent screen: set user type (External/Internal), add scopes email, profile, openid.
#
# Demo app sends X-Public-Demo: 1 — GET /users returns only the seeded Test user (test@emotiongraph.local); scoped calls must use that profile.
# ALLOW_PUBLIC_DEMO_USER_LIST=true
#
# Private app without Bearer (local profile / legacy): GET /users returns all users. Set false when only JWT + demo header should work.
# ALLOW_UNAUTHENTICATED_FULL_USER_LIST=true
#
# Insecure: allow X-User-Id for any user (local scripts only). Demo normally uses X-User-Id only for @emotiongraph.local users.
# ALLOW_X_USER_ID_ANY=false

# Comma-separated emails allowed to call /tracker-config and use /admin (must match users.email). Empty = no admins.
# ADMIN_EMAIL_ALLOWLIST=you@gmail.com

# Local API URL: http://127.0.0.1:8100
# From backend/ (after venv + pip install): .venv/bin/uvicorn app.main:app --reload --host 127.0.0.1 --port 8100
