# --- Speech-to-text (POST /transcribe) — Groq only ---
GROQ_API_KEY=gsk_...
# GROQ_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# --- Structured extraction (POST /extract-logs) ---
# Primary: Claude (Anthropic). If Claude errors, times out, or returns invalid JSON vs schema, the server falls back to Groq.
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_TIMEOUT_SECONDS=90

# Fallback (same key as transcription is fine): Groq chat with JSON mode
# GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile

# Local (default): SQLite file under the backend working directory
# DATABASE_URL=sqlite:///./emotiongraph.db
# Production: PostgreSQL (Railway/Heroku often provide postgres:// — the app normalizes that)
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
# Optional: override allowed browser origins (comma-separated). Defaults include local Vite + deployed frontend.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://emotiongraph.ozayn.com,https://web-production-abed5.up.railway.app

# Optional outbound HTTP proxy (single URL; not applied to API clients yet)
# USE_OUTBOUND_PROXY=false
# OUTBOUND_PROXY_URL=http://username:password@ip:port

# Local API URL: http://127.0.0.1:8100
# From backend/ (after venv + pip install): .venv/bin/uvicorn app.main:app --reload --host 127.0.0.1 --port 8100
